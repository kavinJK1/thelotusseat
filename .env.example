# Razorpay — https://dashboard.razorpay.com/app/website-app-settings/api-keys
#
# Sign up, and Razorpay gives you TEST keys immediately (prefixed rzp_test_).
# You do NOT need the entity or the bank account to develop against these —
# only to switch to live keys (rzp_live_), which requires completed KYC.
#
# Never commit the secret. On Vercel: `vercel env add RAZORPAY_KEY_SECRET`.

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=

# Set this yourself when you create the webhook in the Razorpay dashboard
# (Settings → Webhooks). Point the webhook at:
#
#   https://<your-domain>/api/webhooks/razorpay
#
# and subscribe to the `payment.captured` event. The secret you type into that
# form is the value below — it is how we prove a webhook really came from
# Razorpay and not from someone who guessed the URL.

RAZORPAY_WEBHOOK_SECRET=
